{
  "name": "opl-language",
  "displayName": "OPL Language",
  "description": "Language support, LSP intelligence, and debugger integration for OPL (One Piece Language).",
  "version": "1.0.4",
  "publisher": "Naren-SMU",
  "icon": "images/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Naren3333/opl.git",
    "directory": "vscode-opl"
  },
  "bugs": {
    "url": "https://github.com/Naren3333/opl/issues"
  },
  "homepage": "https://github.com/Naren3333/opl#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "opl",
    "one piece language",
    "pirate syntax",
    "language server",
    "debugger"
  ],
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "activationEvents": [
    "onLanguage:opl",
    "workspaceContains:**/*.opl",
    "onCommand:opl.runCurrentFile",
    "onCommand:opl.debugCurrentFile",
    "onCommand:opl.runFile",
    "onCommand:opl.debugFile"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "opl",
        "aliases": [
          "OPL",
          "One Piece Language"
        ],
        "extensions": [
          ".opl"
        ],
        "icon": {
          "light": "./icons/opl-file.svg",
          "dark": "./icons/opl-file-dark.svg"
        },
        "configuration": "./language-configuration.json"
      }
    ],
    "iconThemes": [
      {
        "id": "opl-file-icons",
        "label": "OPL File Icons",
        "path": "./icons/opl-icon-theme.json"
      }
    ],
    "commands": [
      {
        "command": "opl.runCurrentFile",
        "title": "OPL: Run Current File",
        "category": "OPL",
        "icon": "$(play)"
      },
      {
        "command": "opl.debugCurrentFile",
        "title": "OPL: Debug Current File",
        "category": "OPL",
        "icon": "$(debug-alt)"
      },
      {
        "command": "opl.runFile",
        "title": "Run OPL File",
        "category": "OPL",
        "icon": "$(play)"
      },
      {
        "command": "opl.debugFile",
        "title": "Debug OPL File",
        "category": "OPL",
        "icon": "$(debug-alt)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "opl.runCurrentFile"
        },
        {
          "command": "opl.debugCurrentFile"
        }
      ],
      "editor/title": [
        {
          "command": "opl.runCurrentFile",
          "when": "resourceLangId == opl",
          "group": "navigation@1"
        },
        {
          "command": "opl.debugCurrentFile",
          "when": "resourceLangId == opl",
          "group": "navigation@2"
        }
      ],
      "explorer/context": [
        {
          "command": "opl.runFile",
          "when": "resourceExtname == .opl",
          "group": "navigation@1"
        },
        {
          "command": "opl.debugFile",
          "when": "resourceExtname == .opl",
          "group": "navigation@2"
        }
      ]
    },
    "grammars": [
      {
        "language": "opl",
        "scopeName": "source.opl",
        "path": "./syntaxes/opl.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "opl",
        "path": "./snippets/snippets.json"
      }
    ],
    "debuggers": [
      {
        "type": "opl",
        "label": "OPL Debugger",
        "languages": [
          "opl"
        ],
        "program": "./extension.js",
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the OPL source or bytecode file.",
                "default": "${file}"
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "opl",
            "request": "launch",
            "name": "Run OPL",
            "program": "${file}"
          }
        ]
      }
    ]
  }
}
